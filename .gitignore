# Root .gitignore for Monte Claro

# ========================
# C Build Artifacts
# ========================
*.o
*.obj
*.exe
monte_carlo_simulator
results/*.csv

# ========================
# Frontend / Node.js
# ========================
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# ========================
# Logs
# ========================
*.log
npm-debug.log*

# ========================
# Environment Variables
# ========================
.env
.env.local
.env.production

# ========================
# OS Files
# ========================
.DS_Store
Thumbs.db
desktop.ini

# ========================
# Editor / IDE
# ========================
.vscode/
.idea/
*.suo
*.user
*.sln.docstates
